@using System.Security.Claims

@if (User.Identity?.IsAuthenticated == true && User.Identity.AuthenticationType == "UserAuth")
{
    var email = User.FindFirst(ClaimTypes.Email)?.Value;
    <span class="navbar-text me-3">@email</span>
    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-secondary btn-sm">Logout</button>
    </form>
    <a asp-controller="Account" asp-action="Profile" class="btn btn-outline-primary btn-sm ms-2">Profile</a>
}
else
{
    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-sm me-2">Login</a>
    <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-sm">Register</a>
}
