@model Fun88.Web.Modules.Categories.ViewModels.CategoryPageViewModel
@{
    ViewData["Title"] = Model.Name;
    int totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
}

<nav style="font-size:12px;color:#6c6880;margin-bottom:16px;">
    <a asp-controller="Home" asp-action="Index" style="color:#a29bfe;">Home</a>
    <span style="margin:0 6px;">›</span>
    <span>@Model.Name</span>
</nav>

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
    <h2 style="font-size:18px;font-weight:700;">@Model.Name</h2>
    <span style="font-size:12px;color:#6c6880;">@Model.TotalCount games</span>
</div>

@if (Model.Games.Any())
{
    <div class="game-grid">
        @foreach (var game in Model.Games)
        {
            <partial name="_GameCard" model="game" />
        }
    </div>
}
else
{
    <p style="text-align:center;color:#6c6880;padding:40px;">No games in this category yet.</p>
}

@if (totalPages > 1)
{
    <div class="pagination">
        @if (Model.CurrentPage > 1)
        {
            <a asp-action="Index" asp-route-slug="@Model.Slug" asp-route-page="@(Model.CurrentPage - 1)">← Prev</a>
        }
        @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(totalPages, Model.CurrentPage + 2); i++)
        {
            <a asp-action="Index" asp-route-slug="@Model.Slug" asp-route-page="@i" class="@(i == Model.CurrentPage ? "active" : "")">@i</a>
        }
        @if (Model.CurrentPage < totalPages)
        {
            <a asp-action="Index" asp-route-slug="@Model.Slug" asp-route-page="@(Model.CurrentPage + 1)">Next →</a>
        }
    </div>
}
