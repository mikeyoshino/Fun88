@model Fun88.Web.Modules.Admin.ViewModels.AdminGameFormViewModel
@{
    Layout = "_AdminLayout";
}
<form method="post" action="/admin/games/create" style="max-width:600px">
    @Html.AntiForgeryToken()
    <div style="display:flex;flex-direction:column;gap:1rem">
        <div>
            <label style="display:block;color:rgba(255,255,255,0.5);font-size:0.8rem;margin-bottom:0.3rem">Title *</label>
            <input name="Title" value="@Model.Title" required style="width:100%;padding:0.6rem 0.85rem;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.12);border-radius:8px;color:#fff;font-size:0.95rem" />
        </div>
        <div>
            <label style="display:block;color:rgba(255,255,255,0.5);font-size:0.8rem;margin-bottom:0.3rem">Slug *</label>
            <input name="Slug" id="Slug" value="@Model.Slug" required style="width:100%;padding:0.6rem 0.85rem;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.12);border-radius:8px;color:#fff;font-size:0.95rem" />
        </div>
        <div>
            <label style="display:block;color:rgba(255,255,255,0.5);font-size:0.8rem;margin-bottom:0.3rem">Game URL *</label>
            <input name="GameUrl" value="@Model.GameUrl" required style="width:100%;padding:0.6rem 0.85rem;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.12);border-radius:8px;color:#fff;font-size:0.95rem" />
        </div>
        <div>
            <label style="display:block;color:rgba(255,255,255,0.5);font-size:0.8rem;margin-bottom:0.3rem">Thumbnail URL *</label>
            <input name="ThumbnailUrl" value="@Model.ThumbnailUrl" required style="width:100%;padding:0.6rem 0.85rem;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.12);border-radius:8px;color:#fff;font-size:0.95rem" />
        </div>
        <div>
            <label style="display:block;color:rgba(255,255,255,0.5);font-size:0.8rem;margin-bottom:0.3rem">Description</label>
            <textarea name="Description" rows="3" style="width:100%;padding:0.6rem 0.85rem;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.12);border-radius:8px;color:#fff;font-size:0.95rem;resize:vertical">@Model.Description</textarea>
        </div>
        <div>
            <button type="submit" class="btn btn-primary">Save Game</button>
            <a href="/admin/games" style="margin-left:1rem;color:rgba(255,255,255,0.4);text-decoration:none;font-size:0.9rem">Cancel</a>
        </div>
    </div>
</form>
@section Scripts {
<script>
document.querySelector('[name=Title]')?.addEventListener('input', function() {
    document.getElementById('Slug').value = this.value.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-+|-+$/g,'');
});
</script>
}
